# PyIRCBot Environment Configuration
# Copy this file to .env and modify the values as needed

# IRC Server Settings
IRC_SERVER=your_irc_server_here
IRC_PORT=6667
IRC_CHANNEL=your_channel_here

# Bot Identity
BOT_NICKNAME=your_bot_nickname_here
BOT_USERNAME=your_bot_username_here
BOT_REALNAME=your_bot_realname_here

# Services Authentication (optional)
# Full command to send to authenticate with IRC services after connecting.
# Use /msg format exactly as you would in an IRC client.
# Examples:
#   AUTH_COMMAND=/msg authserv@services.gamesurge.net auth MyNick:MyPassword
#   AUTH_COMMAND=/msg NickServ IDENTIFY MyPassword
#   AUTH_COMMAND=/msg NickServ IDENTIFY MyNick MyPassword
# AUTH_COMMAND=
# Seconds to wait after sending AUTH_COMMAND before joining the channel.
# Increase this if the server needs more time to apply your vhost/IP mask.
# AUTH_DELAY=2

# API Keys (optional - for weather functionality - weatherapi.com)
# WEATHER_API_KEY=your_openweathermap_api_key_here 

# LM Studio (OpenAI-compatible local API) for .qa command
# Set this to the IP or hostname of the machine running LM Studio.
# Use the full /v1/chat/completions endpoint URL.
# Example using LAN IP:  http://192.168.1.100:1234/v1/chat/completions
# Example using hostname: http://mylmstudiobox:1234/v1/chat/completions
LMSTUDIO_BASE_URL=http://your_lmstudio_host_ip:1234/v1/chat/completions
LMSTUDIO_MODEL=your_loaded_lmstudio_model_id
# Optional if your LM Studio server requires auth
# LMSTUDIO_API_KEY=
# Optional timeout for LM Studio requests
LMSTUDIO_TIMEOUT_SECONDS=30

# .qa user rate limit (per user)
QA_RATE_LIMIT_COUNT=3
QA_RATE_LIMIT_WINDOW_MINUTES=30

# IRC-safe outbound message chunk size
IRC_MESSAGE_CHUNK_SIZE=380
